{
  "manifest_version": 3,
  "name": "Video Downloader Pro",
  "version": "1.0",
  "description": "Download avançado de vídeos com yt-dlp",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "notifications",
    "http://localhost:3000/*"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}